% Base style shared by all plot types.
% Height uses the golden ratio relative to width.
\pgfplotsset{
  mdplots-base/.style={
    set layers,
    width=\mdplotWidth,
    height=0.618\mdplotWidth,
    tick align=inside,
    tick pos=left,
    every axis plot/.append style={only marks, mark size=1.5pt, line width=0.8pt, line join=round, mark layer=like plot},
    every mark/.append style={fill=.},
    legend cell align=left,
    legend style={draw=none, fill=none, font=\normalsize},
    cycle list name=mdplots-categorical,
    label style={font=\large},
    tick label style={font=\normalsize},
    title style={font=\Large},
    minor tick num=4,
  },
  % Axis scale variants — combine with mdplots-base via comma syntax
  mdplots-linear/.style={mdplots-base},
  mdplots-square/.style={
    mdplots-base, height=\mdplotWidth,
    every axis plot/.append style={mark size=1.2pt},
  },
  % Per-plot styles — apply with \addplot[mdplots-data] or \addplot[mdplots-model]
  mdplots-data/.style={only marks, mark size=1.5pt},
  mdplots-model/.style={sharp plot, mark=none, color=black, line width=1.5pt, draw opacity=1},
  % Move the title inside the axis at the top-left with a bordered box.
  % Useful for matrix layouts where the title labels a subplot without
  % covering data — transparent fill, accent-colored rounded border.
  mdplots-inset-title/.style={
    title style={
      at={(axis description cs:0.06,0.925)},
      anchor=north west,
      font=\large,
      fill=none,
      draw=blue!50,
      line width=0.8pt,
      rounded corners=3pt,
      inner sep=3pt,
    },
  },
  % Axis style for plotting a family of curves indexed by an ordinal variable
  % (Rouse modes, temperatures, concentrations, q-values). Samples the viridis
  % colormap with the requested number of colors, evenly spaced, and reverts
  % to lines (no marks) since a sequential gradient communicates ordering
  % on its own. Apply as: mdplots-sequential=<N>, where N is the curve count.
  %   \mdplotRouse{...}{mdplots-sequential=12}
  %   \mdplotISF  {...}{mdplots-sequential=5}
  mdplots-sequential/.style={
    cycle list={[samples of colormap={#1 of viridis}]},
    % every axis plot/.append style={only marks=false, mark=none, line width=1pt},
  },
  % Note: xmode=log / ymode=log cannot be inside a named pgfplotsset style.
  % pgfplots requires those keys to be set before axis initialisation
  % completes; styles resolved via the tikz unknown-key pathway arrive too
  % late. The template macros set xmode/ymode as direct \begin{axis} options.
}
